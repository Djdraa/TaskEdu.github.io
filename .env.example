# Variables de entorno para TaskEdu
# Copiar este archivo como .env y llenar con valores reales

# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/taskedu

# Puerto en el que corre el servidor
PORT=3000

# Entorno de ejecución
NODE_ENV=development

# Para producción en Render, usar:
# NODE_ENV=production
# DATABASE_URL=postgresql://...@ep-xxxx.region.neon.tech/taskedu?sslmode=require
